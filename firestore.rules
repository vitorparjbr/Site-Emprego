rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Jobs: leitura pública, escrita pública (site sem autenticação)
    match /jobs/{jobId} {
      allow read: if true;
      allow create: if request.resource.data.employerId is string
                    && request.resource.data.employerId.size() > 0;
      allow update, delete: if resource.data.employerId == request.resource.data.employerId
                            || request.resource.data == null;
    }

    // Subcoleção de candidaturas: qualquer pessoa pode criar e ler
    match /jobs/{jobId}/applications/{appId} {
      allow read, create: if true;
      allow update, delete: if false;
    }

    // Documentos de empregadores: leitura e escrita públicas (sem auth)
    match /employers/{userId} {
      allow read, write: if true;
    }

  }
}
