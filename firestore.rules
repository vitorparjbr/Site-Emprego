rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ────────────────────────────────────────────────────
    // VAGAS: leitura pública, escrita apenas para o dono
    // ────────────────────────────────────────────────────
    match /jobs/{jobId} {
      allow read: if true;

      allow create: if request.auth != null
                    && request.resource.data.employerId == request.auth.uid
                    && request.resource.data.title is string
                    && request.resource.data.title.size() > 0
                    && request.resource.data.location is string
                    && request.resource.data.location.size() > 0;

      allow update: if request.auth != null
                    && resource.data.employerId == request.auth.uid;

      allow delete: if request.auth != null
                    && resource.data.employerId == request.auth.uid;


      // ────────────────────────────────────────────────────
      // CANDIDATURAS: subcoleção de /jobs/{jobId}
      // Criação pública MAS com validação de campos obrigatórios.
      // Leitura somente para o empregador dono da vaga.
      // ────────────────────────────────────────────────────
      match /applications/{appId} {
        allow create: if
          // Campos obrigatórios presentes e não-vazios
          request.resource.data.fullName is string
          && request.resource.data.fullName.size() > 0
          && request.resource.data.email is string
          && request.resource.data.email.size() > 0
          && request.resource.data.phone is string
          && request.resource.data.phone.size() > 0
          // Impede campos extras inesperados além dos definidos
          && request.resource.data.keys().hasOnly([
               'fullName', 'email', 'phone', 'date',
               'resumeFile', 'resumeText'
             ]);

        // Somente o empregador dono da vaga pode ler as candidaturas
        allow read: if request.auth != null
                    && get(/databases/$(database)/documents/jobs/$(jobId)).data.employerId == request.auth.uid;

        // Candidaturas não podem ser modificadas nem apagadas
        allow update, delete: if false;
      }
    }

    // ────────────────────────────────────────────────────
    // EMPREGADORES: leitura pública, criação/atualização
    // apenas pelo próprio usuário autenticado
    // ────────────────────────────────────────────────────
    match /employers/{userId} {
      allow read: if true;

      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.companyName is string
                    && request.resource.data.companyName.size() > 0;

      allow update: if request.auth != null
                    && request.auth.uid == userId;

      allow delete: if false;
    }

    // ────────────────────────────────────────────────────
    // FEEDBACK: escrita somente por usuários autenticados,
    // leitura bloqueada (dados internos da plataforma)
    // ────────────────────────────────────────────────────
    match /feedback/{feedbackId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }

  }
}
